APP_ENV=development
SECRET_KEY=nexusguard-dev-secret-change-in-production-min-32-chars
DATABASE_URL=postgresql+asyncpg://nexus:nexuspass@localhost:5432/nexusguard
REDIS_URL=redis://localhost:6379/0
